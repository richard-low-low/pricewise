{
  "manifest_version": 3,
  "name": "PriceWise - Amazon Price Tracker",
  "version": "1.0.0",
  "description": "Transparent Amazon price history tracker. No data collection, no affiliate hijacking.",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.co.uk/*",
    "*://*.amazon.de/*",
    "*://*.amazon.fr/*",
    "*://*.amazon.co.jp/*",
    "*://*.amazon.ca/*",
    "*://*.amazon.com.au/*",
    "*://*.amazon.it/*",
    "*://*.amazon.es/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/dp/*",
        "*://*.amazon.com/*/dp/*",
        "*://*.amazon.com/gp/product/*",
        "*://*.amazon.co.uk/dp/*",
        "*://*.amazon.co.uk/*/dp/*",
        "*://*.amazon.de/dp/*",
        "*://*.amazon.de/*/dp/*",
        "*://*.amazon.fr/dp/*",
        "*://*.amazon.fr/*/dp/*",
        "*://*.amazon.co.jp/dp/*",
        "*://*.amazon.co.jp/*/dp/*",
        "*://*.amazon.ca/dp/*",
        "*://*.amazon.ca/*/dp/*",
        "*://*.amazon.com.au/dp/*",
        "*://*.amazon.com.au/*/dp/*",
        "*://*.amazon.it/dp/*",
        "*://*.amazon.it/*/dp/*",
        "*://*.amazon.es/dp/*",
        "*://*.amazon.es/*/dp/*"
      ],
      "js": [
        "lib/chart.umd.min.js",
        "utils/constants.js",
        "utils/price-parser.js",
        "utils/storage.js",
        "content/chart-panel.js",
        "content/amazon-product.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
